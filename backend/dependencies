# backend/dependencies.py
"""
Contenedor de dependencias.
Los singletons pesados se crean UNA vez en el lifespan de FastAPI,
no en cada request como en tu versión actual.
"""
from __future__ import annotations
import os
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from infrastructure.market.yahoo_sensor import AsyncMarketSensor
    from infrastructure.ai.gemini_brain import AsyncExpertBrain
    from agents.clips_rules import ClipsRulesEngine


# Estos se populan en el lifespan de main.py
_sensor: "AsyncMarketSensor | None" = None
_brain:  "AsyncExpertBrain | None"  = None
_clips:  "ClipsRulesEngine | None"  = None


def get_sensor() -> "AsyncMarketSensor":
    assert _sensor is not None, "Sensor no inicializado"
    return _sensor


def get_brain() -> "AsyncExpertBrain":
    assert _brain is not None, "Brain no inicializado"
    return _brain


def get_clips() -> "ClipsRulesEngine":
    assert _clips is not None, "CLIPS no inicializado"
    return _clips